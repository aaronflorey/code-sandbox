#!/usr/bin/env bash
set -euo pipefail

STAGED=$(git diff --cached --name-only)

COMPILE_LAUNCHER=false
COMPILE_ENTRYPOINT=false

echo "${STAGED}" | grep -q 'code-sandbox\.ab$'  && COMPILE_LAUNCHER=true
echo "${STAGED}" | grep -q 'entrypoint\.ab$'    && COMPILE_ENTRYPOINT=true

if ! "${COMPILE_LAUNCHER}" && ! "${COMPILE_ENTRYPOINT}"; then
    exit 0
fi

# Check that amber is installed
if ! command -v amber &>/dev/null; then
    echo "Error: amber is not installed. Install it with:"
    echo '  bash <(curl -sL "https://github.com/amber-lang/amber/releases/download/0.5.1-alpha/install.sh")'
    exit 1
fi

if "${COMPILE_LAUNCHER}"; then
    echo "Compiling code-sandbox.ab -> code-sandbox ..."
    amber build code-sandbox.ab code-sandbox
    chmod +x code-sandbox
    
    # Generate hash of compiled launcher for update checking
    if command -v sha256sum &>/dev/null; then
        sha256sum code-sandbox | cut -d' ' -f1 > LAUNCHER_HASH
    else
        shasum -a 256 code-sandbox | cut -d' ' -f1 > LAUNCHER_HASH
    fi
    
    git add code-sandbox LAUNCHER_HASH
    echo "Compiled code-sandbox and LAUNCHER_HASH added to commit."
fi

if "${COMPILE_ENTRYPOINT}"; then
    echo "Compiling entrypoint.ab -> entrypoint.sh ..."
    amber build entrypoint.ab entrypoint.sh
    chmod +x entrypoint.sh
    git add entrypoint.sh
    echo "Compiled entrypoint.sh added to commit."
fi
