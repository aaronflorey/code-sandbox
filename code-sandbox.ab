import { file_exists, dir_exists } from "std/fs"
import { env_var_get, input_prompt } from "std/env"
import { trim, split, starts_with, slice, rpad, uppercase } from "std/text"

let IMAGE_NAME = "ghcr.io/aaronflorey/code-sandbox:latest"
let UPDATE_CHECK_INTERVAL_SECONDS = 43200
let SCRIPT_REPO = "aaronflorey/code-sandbox"

fun show_help() {
    echo "Usage: code-sandbox [options] [command [args...]]"
    echo ""
    echo "Options:"
    echo "  --build                 Build the local Docker image"
    echo "  --pull                  Pull the latest pre-built Docker image"
    echo "  --update                Force an immediate update check before launch"
    echo "  --shell                 Open a bash shell (skip agent menu)"
    echo "  --skip-permissions      Launch supported agents with their permission bypass flag"
    echo "  --languages <list>      Install mise languages (comma-separated)"
    echo "  --languages=<list>      Same as above"
    echo "  -h, --help              Show this help message"
    echo "  (env) CODE_SANDBOX_NO_UPDATE_CHECK=1 Disable periodic auto-pull checks"
    echo ""
    echo "Command Passing:"
    echo "  Any non-option argument is treated as the container command."
    echo "  Use -- to pass arguments that start with dashes."
    echo ""
    echo "Examples:"
    echo "  code-sandbox --shell"
    echo "  code-sandbox --languages go,rust -- shell"
    echo "  code-sandbox -- codex --help"
}

fun update_check_stamp_path(): Text {
    let home = trust $ printenv HOME $
    return "{home}/.cache/code-sandbox/last-update-check"
}

fun should_check_for_updates(stamp_file: Text): Bool {
    if not file_exists(stamp_file) {
        return true
    }

    let now_epoch = trust $ date +%s $
    let last_check = trust $ cat "{stamp_file}" 2>/dev/null || echo "0" $
    let now_epoch_trimmed = trim(now_epoch)
    let last_check_trimmed = trim(last_check)
    let last_valid = trust $ echo "{last_check_trimmed}" | grep -E "^[0-9][0-9]*\$" || true $
    if trim(last_valid) == "" {
        return true
    }
    let elapsed = trust $ expr "{now_epoch_trimmed}" - "{last_check_trimmed}" $
    let elapsed_trimmed = trim(elapsed)
    let should_check = trust $ [ "{elapsed_trimmed}" -ge "{UPDATE_CHECK_INTERVAL_SECONDS}" ] && echo "1" || echo "0" $

    return trim(should_check) == "1"
}

fun write_update_check_stamp(stamp_file: Text): Null {
    let cache_dir = trust $ dirname "{stamp_file}" $
    trust $ mkdir -p "{cache_dir}" $
    let now_epoch = trust $ date +%s $
    trust $ echo "{now_epoch}" > "{stamp_file}" $
}

fun parse_bool(value: Text): Bool {
    let normalized = uppercase(trim(value))
    return normalized == "1" or normalized == "TRUE" or normalized == "YES" or normalized == "Y" or normalized == "ON"
}

fun fetch_remote_launcher_hash(): Text {
    let hash_url = "https://raw.githubusercontent.com/{SCRIPT_REPO}/main/LAUNCHER_HASH"
    let response = $ curl -fsSL "{hash_url}" 2>/dev/null $ failed {
        return ""
    }
    return trim(response)
}

fun get_local_launcher_hash(): Text {
    let script_path = trust $ readlink -f "\$0" 2>/dev/null || realpath "\$0" 2>/dev/null || echo "\$0" $
    let hash = ""
    
    // Try sha256sum first (Linux), then shasum (macOS)
    hash = $ sha256sum "{script_path}" 2>/dev/null | cut -d' ' -f1 $ failed {
        hash = $ shasum -a 256 "{script_path}" 2>/dev/null | cut -d' ' -f1 $ failed {
            ""
        }
    }
    
    return trim(hash)
}

fun check_script_update_and_pull(): Bool {
    let local_hash = get_local_launcher_hash()
    if local_hash == "" {
        return false
    }

    let remote_hash = fetch_remote_launcher_hash()
    if remote_hash == "" {
        return false
    }

    if remote_hash != local_hash {
        let local_short = slice(local_hash, 0, 8)
        let remote_short = slice(remote_hash, 0, 8)

        echo "New code-sandbox launcher version detected ({local_short}... -> {remote_short}...)."
        echo "Pulling latest sandbox image so tools/runtime stay aligned ..."
        let pull_failed = false
        $ docker pull "{IMAGE_NAME}" $ failed {
            pull_failed = true
        }
        if pull_failed {
            echo "Warning: image pull failed while checking launcher updates."
        }
        echo "Update launcher with:"
        echo "  curl -fsSL https://raw.githubusercontent.com/{SCRIPT_REPO}/main/code-sandbox -o /usr/local/bin/code-sandbox"
        echo "  chmod +x /usr/local/bin/code-sandbox"
        return not pull_failed
    }

    return false
}

fun maybe_check_for_updates(force_check: Bool): Null {
    let no_update_check = env_var_get("CODE_SANDBOX_NO_UPDATE_CHECK") failed { "" }
    let update_check_enabled = force_check or not parse_bool(no_update_check)

    if update_check_enabled {
        let stamp_file = update_check_stamp_path()
        if force_check or should_check_for_updates(stamp_file) {
            let pulled_for_script_update = check_script_update_and_pull()
            if pulled_for_script_update {
                write_update_check_stamp(stamp_file)
            } else {
                echo "Checking for updated sandbox image ..."
                let pull_failed = false
                let pull_output = $ docker pull "{IMAGE_NAME}" 2>&1 $ failed {
                    pull_failed = true
                    ""
                }

                if pull_failed {
                    echo "Warning: update check failed; continuing with local image."
                } else {
                    write_update_check_stamp(stamp_file)

                    let pulled_new = trust $ printf "%s\n" "{pull_output}" | grep -E "Downloaded newer image|Status: Downloaded newer image" || true $
                    if trim(pulled_new) != "" {
                        echo "Updated local image to the latest published version."
                    }
                }
            }
        }
    }
}

fun pull_image() {
    echo "Pulling {IMAGE_NAME} ..."
    $ docker pull "{IMAGE_NAME}" $?
}

fun build_image() {
    let script = trust $ readlink -f /proc/self/exe 2>/dev/null || which code-sandbox 2>/dev/null || echo "." $
    let script_dir = trust $ dirname "{script}" $

    if not file_exists("{script_dir}/Dockerfile") {
        echo "Error: Dockerfile not found in {script_dir}"
        echo "Use --pull to fetch the pre-built image, or run from the repo directory to build locally."
        exit 1
    }

    echo "Building {IMAGE_NAME} locally ..."
    $ docker build -t "{IMAGE_NAME}" "{script_dir}" $?
}

fun ensure_image(force_update: Bool) {
    let image_missing = false
    silent $ docker image inspect "{IMAGE_NAME}" $ failed {
        image_missing = true
    }

    if image_missing {
        echo "Image {IMAGE_NAME} not found locally. Pulling..."
        pull_image()?
        write_update_check_stamp(update_check_stamp_path())
    } else {
        maybe_check_for_updates(force_update)
    }
}

fun container_name(): Text {
    let abs_path = trust $ pwd -P $
    let base = trust $ basename "{abs_path}" $
    let hash = trust $ echo -n "{abs_path}" | md5sum 2>/dev/null || md5 -q -s "{abs_path}" 2>/dev/null || echo -n "{abs_path}" | shasum | cut -c1-32 $
    let hash_trimmed = slice(trim(hash), 0, 12)
    return "code-sandbox-{base}-{hash_trimmed}"
}

fun csv_contains(csv: Text, value: Text): Bool {
    if csv == "" {
        return false
    }

    let parts = split(csv, ",")
    for part in parts {
        if trim(part) == value {
            return true
        }
    }

    return false
}

fun append_csv_unique(csv: Text, value: Text): Text {
    if csv_contains(csv, value) {
        return csv
    }

    if csv == "" {
        return value
    }

    return "{csv},{value}"
}

fun marker_exists(project_dir: Text, marker: Text): Bool {
    let found = trust $ find "{project_dir}" -maxdepth 2 -type f -name "{marker}" -print -quit 2>/dev/null $
    return trim(found) != ""
}

fun detect_languages(project_dir: Text): Text {
    let detected = ""

    if marker_exists(project_dir, "composer.json") {
        detected = append_csv_unique(detected, "php")
    }
    if marker_exists(project_dir, "go.mod") {
        detected = append_csv_unique(detected, "go")
    }
    if marker_exists(project_dir, "Cargo.toml") {
        detected = append_csv_unique(detected, "rust")
    }
    if marker_exists(project_dir, "Gemfile") or marker_exists(project_dir, "*.gemspec") {
        detected = append_csv_unique(detected, "ruby")
    }
    if marker_exists(project_dir, "pom.xml") or marker_exists(project_dir, "build.gradle") or marker_exists(project_dir, "build.gradle.kts") {
        detected = append_csv_unique(detected, "java")
    }
    if marker_exists(project_dir, "pyproject.toml") or marker_exists(project_dir, "requirements.txt") or marker_exists(project_dir, "setup.py") or marker_exists(project_dir, "Pipfile") {
        detected = append_csv_unique(detected, "python")
    }
    if marker_exists(project_dir, "build.zig") {
        detected = append_csv_unique(detected, "zig")
    }
    if marker_exists(project_dir, "rebar.config") or marker_exists(project_dir, "erlang.mk") {
        detected = append_csv_unique(detected, "erlang")
    }
    if marker_exists(project_dir, "mix.exs") {
        detected = append_csv_unique(detected, "elixir")
    }

    return detected
}

fun select_languages(): Text {
    let pwd = trust $ pwd $

    if file_exists("{pwd}/.mise.toml") or file_exists("{pwd}/mise.toml") or dir_exists("{pwd}/.mise") {
        return "__mise_toml__"
    }

    let detected = detect_languages(pwd)
    if detected != "" {
        echo "Auto-detected languages from project files: {detected}"
        return detected
    }

    echo ""
    echo "Select languages to install via mise (comma-separated, all, or Enter for none):"
    echo "  php  go  rust  ruby  java  python  zig  erlang  elixir"
    echo ""

    let selection = input_prompt("Languages: ")
    return selection
}

fun env_flags(): Text {
    let flags = ""
    let vars = [
        "OPENAI_API_KEY", "OPENAI_BASE_URL", "OPENAI_ORG_ID",
        "ANTHROPIC_API_KEY", "ANTHROPIC_BASE_URL",
        "GOOGLE_API_KEY", "GEMINI_API_KEY", "GOOGLE_CLOUD_PROJECT",
        "GITHUB_TOKEN", "GH_TOKEN",
        "GROQ_API_KEY", "MISTRAL_API_KEY", "DEEPSEEK_API_KEY", "OPENROUTER_API_KEY",
        "AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY", "AWS_SESSION_TOKEN", "AWS_REGION"
    ]

    for var in vars {
        let val = env_var_get(var) failed {
            continue
        }
        if trim(val) == "" {
            continue
        }
        flags += " -e {var}={val}"
    }

    let pwd = trust $ pwd $
    if file_exists("{pwd}/.env.sandbox") {
        let content = trust $ cat "{pwd}/.env.sandbox" $
        let lines = split(content, "\n")
        for line in lines {
            let trimmed = trim(line)
            if trimmed == "" or starts_with(trimmed, "#") {
                continue
            }

            let has_equals = trust $ printf '%s' "{trimmed}" | grep -q "=" && echo "1" || echo "0" $
            if trim(has_equals) != "1" {
                continue
            }

            let key = trim(trust $ printf '%s' "{trimmed}" | cut -d= -f1 $)
            let value = trim(trust $ printf '%s' "{trimmed}" | cut -d= -f2- $)

            if key == "" or value == "" {
                continue
            }

            flags += " -e {key}={value}"
        }
    }

    return flags
}

fun volume_flags(source_dir: Text, folder: Text, skip_permissions: Bool): Text {
    let flags = ""
    let home = trust $ printenv HOME $
    let shadow_root = "/workspace/.sandbox-host-config"

    flags += " -v {source_dir}:/workspace/{folder}"

    let config_dirs = [".codex", ".claude", ".gemini", ".opencode", ".code", ".copilot", ".agents"]
    for dir in config_dirs {
        if dir_exists("{home}/{dir}") {
            if skip_permissions {
                flags += " -v {home}/{dir}:{shadow_root}/{dir}:ro"
            } else {
                flags += " -v {home}/{dir}:/workspace/{dir}"
            }
        }
    }

    if dir_exists("{home}/.config/opencode") {
        if skip_permissions {
            flags += " -v {home}/.config/opencode:{shadow_root}/.config/opencode:ro"
        } else {
            flags += " -v {home}/.config/opencode:/workspace/.config/opencode"
        }
    }

    if dir_exists("{home}/.cache/opencode") {
        if skip_permissions {
            flags += " -v {home}/.cache/opencode:{shadow_root}/.cache/opencode:ro"
        } else {
            flags += " -v {home}/.cache/opencode:/workspace/.cache/opencode"
        }
    }

    if dir_exists("{home}/.local/share/opencode") {
        if skip_permissions {
            flags += " -v {home}/.local/share/opencode:{shadow_root}/.local/share/opencode:ro"
        } else {
            flags += " -v {home}/.local/share/opencode:/workspace/.local/share/opencode"
        }
    }

    if dir_exists("{home}/.local/state/opencode") {
        if skip_permissions {
            flags += " -v {home}/.local/state/opencode:{shadow_root}/.local/state/opencode:ro"
        } else {
            flags += " -v {home}/.local/state/opencode:/workspace/.local/state/opencode"
        }
    }

    let config_files = [".claude.json"]
    for file in config_files {
        if file_exists("{home}/{file}") {
            if skip_permissions {
                flags += " -v {home}/{file}:{shadow_root}/{file}:ro"
            } else {
                flags += " -v {home}/{file}:/workspace/{file}"
            }
        }
    }

    if dir_exists("{home}/.ssh") {
        flags += " -v {home}/.ssh:/workspace/.ssh:ro"
    }

    if file_exists("{home}/.gitconfig") {
        flags += " -v {home}/.gitconfig:/workspace/.gitconfig:ro"
    }

    flags += " -v code-sandbox-bun-cache:/home/code/.bun"
    flags += " -v code-sandbox-mise-data:/workspace/.local/share/mise"

    return flags
}

fun show_menu(): Text {
    echo ""
    echo "Select an agent to launch:"
    echo "  1) code      - Every Code (multi-model agent)"
    echo "  2) claude    - Claude Code"
    echo "  3) codex     - OpenAI Codex"
    echo "  4) gemini    - Gemini CLI"
    echo "  5) opencode  - OpenCode"
    echo "  6) copilot   - GitHub Copilot"
    echo "  7) shell     - Bash shell"
    echo ""

    let choice = input_prompt("Choice [1-7]: ")

    if choice == "1": return "code"
    if choice == "2": return "claude"
    if choice == "3": return "codex"
    if choice == "4": return "gemini"
    if choice == "5": return "opencode"
    if choice == "6": return "copilot"
    if choice == "7": return "bash"

    echo "Invalid choice."
    exit 1
}

fun collect_args(args: [Text], start: Int): Text {
    let result = ""
    let j = start
    loop {
        if j >= len(args) {
            break
        }
        if result != "" {
            result += " "
        }
        result += args[j]
        j += 1
    }
    return result
}

fun resolve_cmd(shell_mode: Bool, explicit_cmd: Bool, pass_args: Text): Text {
    if shell_mode: return "bash"
    if explicit_cmd and pass_args != "": return pass_args
    return show_menu()
}

fun skip_permissions_flag(cmd: Text): Text {
    if {
        cmd == "claude" {
            return " --dangerously-skip-permissions"
        }
        cmd == "codex" {
            return " --dangerously-bypass-approvals-and-sandbox"
        }
        cmd == "gemini" {
            return " --yolo"
        }
        cmd == "copilot" {
            return " --allow-all-tools"
        }
        cmd == "code" {
            return " --no-approval"
        }
        else {
            return ""
        }
    }
}

fun apply_skip_permissions(cmd: Text, skip_permissions: Bool): Text {
    if not skip_permissions {
        return cmd
    }

    let flag = skip_permissions_flag(cmd)
    if flag == "" {
        return cmd
    }

    return "{cmd}{flag}"
}

fun get_container_state(cname: Text): Text {
    let json = $ docker inspect "{cname}" 2>/dev/null $ failed {
        return "none"
    }
    let state = trust $ echo "{json}" | jq -r ".[0].State.Status" $
    return trim(state)
}

fun sandbox_setup(pwd: Text, folder: Text): Text {
    silent $ git -C "{pwd}" rev-parse --is-inside-work-tree $ failed {
        return ""
    }

    let timestamp = trust $ date +%Y%m%d-%H%M%S $
    let sandbox_dir = "/tmp/code-sandbox/{folder}-{timestamp}"
    let padded = rpad(sandbox_dir, " ", 55)

    echo ""
    echo "┌─────────────────────────────────────────────────────────────────┐"
    echo "│  🛡️  Safe Mode: isolated sandbox workspace                       │"
    echo "│                                                                  │"
    echo "│  Git repo detected. The agent will work in an isolated copy     │"
    echo "│  of your project — your workspace files stay untouched until    │"
    echo "│  you decide what to do when the session ends.                   │"
    echo "│                                                                  │"
    echo "│  Sandbox : {padded}│"
    echo "│  On exit : you will be asked what to do with any changes.       │"
    echo "└─────────────────────────────────────────────────────────────────┘"
    echo ""

    trust $ mkdir -p /tmp/code-sandbox $

    $ git clone --quiet "{pwd}" "{sandbox_dir}" $ failed {
        echo "Warning: git clone failed — using direct workspace."
        echo ""
        return ""
    }

    trust $ rsync -a --exclude=.git "{pwd}/" "{sandbox_dir}/" $
    silent trust $ git -C "{sandbox_dir}" remote set-url origin "{pwd}" $

    // Commit any pre-existing dirty state as a baseline so the agent's work
    // lands in a separate, clean commit — useful for option C (branch push).
    let has_diff = false
    silent $ git -C "{sandbox_dir}" diff --quiet $ failed { has_diff = true }
    let has_cached = false
    silent $ git -C "{sandbox_dir}" diff --cached --quiet $ failed { has_cached = true }
    let untracked = trust $ git -C "{sandbox_dir}" ls-files --others --exclude-standard $
    if has_diff or has_cached or untracked != "" {
        trust $ git -C "{sandbox_dir}" add -A $
        silent trust $ git -C "{sandbox_dir}" commit -m "pre-sandbox: uncommitted host changes" --quiet $
    }

    return sandbox_dir
}

fun sandbox_exit(sandbox_dir: Text, project_dir: Text): Null {
    echo ""
    echo "┌─────────────────────────────────────────────────────────────────┐"
    echo "│  🛡️  Sandbox session ended — what should happen to the changes? │"
    echo "│                                                                  │"
    echo "│  A) Copy changes → workspace   (additive rsync, safe)          │"
    echo "│  B) Mirror sandbox → workspace (rsync --delete, may remove)    │"
    echo "│  C) Create new branch in workspace with the sandbox changes     │"
    echo "│  D) Discard — leave workspace exactly as it was                 │"
    echo "└─────────────────────────────────────────────────────────────────┘"
    echo ""

    let choice = trust $ if [ -t 0 ]; then read -r -p "Choice [A/B/C/D]: " _c </dev/tty 2>/dev/tty || _c="D"; else _c="D"; fi; echo "\$_c" $
    let choice_upper = uppercase(choice)

    if {
        choice_upper == "A" {
            echo "→ Copying sandbox changes to workspace (additive)..."
            trust $ rsync -a --exclude=.git "{sandbox_dir}/" "{project_dir}/" $
            echo "✓ Done."
        }
        choice_upper == "B" {
            echo "→ Mirroring sandbox to workspace (adds + deletes)..."
            trust $ rsync -a --delete --exclude=.git "{sandbox_dir}/" "{project_dir}/" $
            echo "✓ Done."
        }
        choice_upper == "C" {
            let branch = trust $ echo "sandbox/\$(date +%Y%m%d-%H%M%S)" $
            echo "→ Creating branch {branch}..."
            trust $ git -C "{sandbox_dir}" add -A $
            silent $ git -C "{sandbox_dir}" diff --cached --quiet $ failed {
                trust $ git -C "{sandbox_dir}" commit -m "sandbox: agent changes" --quiet $
            }
            let push_failed = false
            $ git -C "{sandbox_dir}" push origin "HEAD:refs/heads/{branch}" --quiet $ failed {
                push_failed = true
            }
            if push_failed {
                echo "✗ Branch push failed — falling back to additive rsync..."
                trust $ rsync -a --exclude=.git "{sandbox_dir}/" "{project_dir}/" $
                echo "✓ Changes copied to workspace instead."
            } else {
                echo "✓ Branch '{branch}' created in workspace."
                echo "  Switch to it with: git checkout {branch}"
            }
        }
        else {
            echo "→ Workspace unchanged."
        }
    }

    trust $ rm -rf "{sandbox_dir}" $
}

main(args) {
    let do_pull = false
    let do_build = false
    let do_update = false
    let shell_mode = false
    let skip_permissions = false
    let help_mode = false
    let languages = "__prompt__"
    let pass_args = ""
    let explicit_cmd = false

    // Amber includes the script path in args[0], so parse user args from index 1.
    let i = 1
    loop {
        if i >= len(args) {
            break
        }
        let arg = args[i]

        if {
            arg == "--pull" {
                do_pull = true
            }
            arg == "--build" {
                do_build = true
            }
            arg == "--update" {
                do_update = true
            }
            arg == "--shell" {
                shell_mode = true
            }
            arg == "--skip-permissions" {
                skip_permissions = true
            }
            arg == "--help" or arg == "-h" {
                help_mode = true
            }
            arg == "--languages" {
                if i + 1 >= len(args) {
                    echo "Error: --languages requires a value."
                    echo "Use --help for usage."
                    exit 1
                }
                i += 1
                languages = args[i]
            }
            starts_with(arg, "--languages=") {
                languages = trust $ echo "{arg}" | cut -d= -f2- $
            }
            arg == "--" {
                pass_args = collect_args(args, i + 1)
                explicit_cmd = true
                break
            }
            starts_with(arg, "-") {
                echo "Error: Unknown option: {arg}"
                echo "Use --help for usage."
                exit 1
            }
            else {
                pass_args = collect_args(args, i)
                explicit_cmd = true
                break
            }
        }

        i += 1
    }

    if help_mode {
        show_help()
        exit 0
    }

    // Get the image
    if {
        do_build {
            build_image()?
        }
        do_pull {
            pull_image()?
        }
        else {
            ensure_image(do_update)?
        }
    }

    let cname = container_name()
    let state = get_container_state(cname)

    if state == "running" {
        echo "Attaching to running container {cname} ..."
        let cmd = apply_skip_permissions(resolve_cmd(shell_mode, explicit_cmd, pass_args), skip_permissions)
        $ exec docker exec -it -e TERM=xterm-256color -e COLORTERM=truecolor -e FORCE_COLOR=1 "{cname}" gosu code {cmd} $?
    }

    if state != "none" {
        silent trust $ docker rm "{cname}" $
    }

    // Language selection (only for new containers)
    if languages == "__prompt__" {
        languages = select_languages()
    }

    let cmd = apply_skip_permissions(resolve_cmd(shell_mode, explicit_cmd, pass_args), skip_permissions)

    // Build docker run command
    let host_uid = trust $ id -u $
    let host_gid = trust $ id -g $
    let term = "xterm-256color"
    let pwd = trust $ pwd -P $
    let folder = trust $ basename "{pwd}" $
    let project_dir = "/workspace/{folder}"

    // Set up sandbox on the host before starting the container.
    // The sandbox dir is mounted in place of the real project, so even
    // a destructive agent command cannot touch the original workspace.
    let sandbox_dir = sandbox_setup(pwd, folder)
    let source_dir = pwd
    if sandbox_dir != "" {
        source_dir = sandbox_dir
    }

    let run_cmd = "docker run -it --rm"
    run_cmd += " --name {cname}"
    run_cmd += " --hostname code-sandbox"
    run_cmd += " -w {project_dir}"
    run_cmd += " --network bridge"
    run_cmd += " --tmpfs /tmp:exec,size=2g"
    run_cmd += " --security-opt=no-new-privileges"
    run_cmd += " --pids-limit=500"
    run_cmd += " --log-driver=local --log-opt max-size=10m"
    run_cmd += " -e HOST_UID={host_uid} -e HOST_GID={host_gid} -e TERM={term}"
    run_cmd += " -e SANDBOX_PROJECT_DIR={project_dir}"

    if languages != "" {
        run_cmd += " -e SANDBOX_LANGUAGES={languages}"
    }

    if skip_permissions {
        run_cmd += " -e SANDBOX_SHADOW_CONFIGS=1"
        run_cmd += " -e SANDBOX_HOST_CONFIG_ROOT=/workspace/.sandbox-host-config"
    }

    run_cmd += volume_flags(source_dir, folder, skip_permissions)
    run_cmd += env_flags()
    run_cmd += " {IMAGE_NAME} {cmd}"

    if sandbox_dir != "" {
        let agent_exit = 0
        $ {run_cmd} $ failed(code) {
            agent_exit = code
        }
        sandbox_exit(sandbox_dir, pwd)
        trust $ exit {agent_exit} $
    } else {
        $ exec {run_cmd} $?
    }
}
